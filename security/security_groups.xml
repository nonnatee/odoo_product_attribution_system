<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_pim" model="ir.module.category">
        <field name="name">Product Information Management (PIM)</field>
        <field name="description">User roles and permission gates for PIM product specifications and lifecycles.</field>
        <field name="sequence">15</field>
    </record>

    <record model="res.groups.privilege" id="res_groups_privilege_pim">
        <field name="name">Product Information Management (PIM)</field>
        <field name="category_id" ref="module_category_pim"/>
        <field name="sequence">15</field>
    </record>

    <record id="group_pim_user" model="res.groups">
        <field name="name">Operator</field>
        <field name="privilege_id" ref="res_groups_privilege_pim"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_pim_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_pim"/>
        <field name="implied_ids" eval="[(4, ref('group_pim_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>
    </record>
</odoo>
