<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_category_form_view_inherit" model="ir.ui.view">
        <field name="name">product.category.form.inherit</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='first']" position="after">
                <group name="attributes" string="Product Attributes">
                    <field name="attribute_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    <field name="attribute_set_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    <field name="all_inherited_attribute_ids" widget="many2many_tags" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
